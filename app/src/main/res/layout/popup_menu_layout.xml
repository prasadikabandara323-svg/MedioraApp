<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="200dp"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/menu_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:weightSum="1"
        android:padding="5dp">

        <!-- ඉහළ මෙනු අයිතම සියල්ලම මෙම LinearLayout එක තුළ ඇත -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/menu_home"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/hom" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="15dp" android:text="Home" android:textColor="#0E3982" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menu_pharmacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/phar" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="15dp" android:text="Pharmacy" android:textColor="#0E3982" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menu_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/prof" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="15dp" android:text="Health Profile" android:textColor="#0E3982" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menu_scancode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/scn" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="15dp" android:text="Scancode" android:textColor="#0E3982" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menu_ebooking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/book" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="15dp" android:text="E-Booking" android:textColor="#0E3982" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menu_mymed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/med" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="15dp" android:text="My Med" android:textColor="#0E3982" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menu_chat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/chat" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="15dp" android:text="Chat with your Doctor" android:textColor="#0E3982" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menu_review"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/review" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="15dp" android:text="Review" android:textColor="#0E3982" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menu_setting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/sett" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="15dp" android:text="Settings" android:textColor="#0E3982" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menu_about"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/about" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="15dp" android:text="About Us" android:textColor="#0E3982" />
            </LinearLayout>
        </LinearLayout>

        <!-- Logout බොත්තම දැන් පතුලටම යනු ඇත -->
        <LinearLayout
            android:id="@+id/menu_logout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/img" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="15dp" android:text="Logout" android:textColor="#FF0000" android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>