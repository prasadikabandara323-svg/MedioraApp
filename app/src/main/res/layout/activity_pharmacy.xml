<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:tools2="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EBF9FA"
    android:fitsSystemWindows="true"
    tools:context=".PharmacyActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigationBar"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:background="#BCE3F7"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerInParent="true"
                    android:padding="8dp"
                    android:contentDescription="@string/back"
                    android:src="@drawable/arrow"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    app:tint="#191D63" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:layout_marginStart="5dp"
                    android:layout_toEndOf="@id/btnBack"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/pharmacy_title"
                    android:textColor="#191D63"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btnMail"  android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerInParent="true"
                    android:contentDescription="@string/notification1"
                    android:scaleType="fitCenter"
                    android:clickable="true"    android:focusable="true"    android:background="?android:attr/selectableItemBackgroundBorderless" android:src="@drawable/mail" />
            </RelativeLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="23dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="20dp">

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_toStartOf="@id/icSearch"
                        android:background="@android:color/transparent"
                        android:hint="@string/search1"
                        android:importantForAutofill="no"
                        android:inputType="text"
                        android:textColorHint="#7E7E7E"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/icSearch"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerInParent="true"
                        android:contentDescription="@string/search2"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="#000000" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/btnUploadPrescription"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#4A49C6"
                app:cardCornerRadius="15dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Upload Prescription"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:padding="12dp">

                <LinearLayout
                    android:id="@+id/btnPainRelief"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:focusable="true"
                    android:clickable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <androidx.cardview.widget.CardView
                        android:layout_width="95dp"
                        android:layout_height="85dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/todo"
                            android:scaleType="centerCrop"
                            android:src="@drawable/pain" />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/pain_relief"
                        android:textColor="#191D63"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textAlignment="center" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnAntibiotics"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:focusable="true"
                    android:clickable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <androidx.cardview.widget.CardView
                        android:layout_width="95dp"
                        android:layout_height="85dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/todo1"
                            android:scaleType="centerCrop"
                            android:src="@drawable/antibiotic" />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/antibiotics1"
                        android:textColor="#191D63"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textAlignment="center" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnVitamins"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:focusable="true"
                    android:clickable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <androidx.cardview.widget.CardView
                        android:layout_width="95dp"
                        android:layout_height="85dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/todo3"
                            android:scaleType="centerCrop"
                            android:src="@drawable/vitamin" />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/vitamins_amp_nsupplement"
                        android:textAlignment="center"
                        android:textColor="#191D63"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnColdFlu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:focusable="true"
                    android:clickable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <androidx.cardview.widget.CardView
                        android:layout_width="95dp"
                        android:layout_height="85dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/todo4"
                            android:scaleType="centerCrop"
                            android:src="@drawable/cold" />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/cold_amp_flu1"
                        android:textColor="#191D63"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textAlignment="center" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnBabyCare"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:focusable="true"
                    android:clickable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <androidx.cardview.widget.CardView
                        android:layout_width="95dp"
                        android:layout_height="85dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/todo11"
                            android:scaleType="centerCrop"
                            android:src="@drawable/baby" />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/baby_amp_mother_ncare"
                        android:textAlignment="center"
                        android:textColor="#191D63"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnDiabetesCare"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:focusable="true"
                    android:clickable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <androidx.cardview.widget.CardView
                        android:layout_width="95dp"
                        android:layout_height="85dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/todo12"
                            android:scaleType="centerCrop"
                            android:src="@drawable/diabates" />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/diabetes_care"
                        android:textColor="#191D63"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textAlignment="center" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnBloodPressure"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:focusable="true"
                    android:clickable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <androidx.cardview.widget.CardView
                        android:layout_width="95dp"
                        android:layout_height="85dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/todo13"
                            android:scaleType="fitCenter"
                            android:padding="6dp"
                            android:src="@drawable/heart" />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/heart_amp_blood_npressure"
                        android:textAlignment="center"
                        android:textColor="#191D63"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnSkinCare"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:focusable="true"
                    android:clickable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <androidx.cardview.widget.CardView
                        android:layout_width="95dp"
                        android:layout_height="85dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/todo10"
                            android:scaleType="centerCrop"
                            android:src="@drawable/skin" />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/skin_care"
                        android:textColor="#191D63"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textAlignment="center" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnMedicalDevices"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:focusable="true"
                    android:clickable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <androidx.cardview.widget.CardView
                        android:layout_width="95dp"
                        android:layout_height="85dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/todo9"
                            android:scaleType="centerCrop"
                            android:src="@drawable/medicine" />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/medical_devices"
                        android:textColor="#191D63"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textAlignment="center" />
                </LinearLayout>
            </GridLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavigationBar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="#BCE3F7"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:weightSum="4">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            tools2:ignore="UseCompoundDrawables">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/todo8"
                android:src="@drawable/home" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/home"
                android:textColor="#191D63"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPharmacy"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            tools2:ignore="UseCompoundDrawables">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/todo7"
                android:src="@drawable/pharmacy" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/pharmacy"
                android:textColor="#191D63"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navEChanneling"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            tools2:ignore="UseCompoundDrawables">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/todo6"
                android:src="@drawable/echaneling" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/e_chaneling"
                android:textColor="#191D63"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            tools2:ignore="UseCompoundDrawables">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:scaleType="fitCenter"
                android:contentDescription="Account Icon"
                android:src="@drawable/account" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Account"
                android:textColor="#191D63"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>