<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E3F2FD">

    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:padding="15dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentStart="true"
            android:layout_centerInParent="true"
            android:src="@drawable/arrow" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Review"
            android:textColor="#1A237E"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnMail"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:layout_centerInParent="true"
            android:src="@drawable/mail" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/topBar"
        android:layout_above="@id/bottomNavigation"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Name"
            android:textColor="#1A237E"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rate your experience with our app"
            android:textColor="#78909C"
            android:textSize="14sp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="25dp" />

        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:rating="5.0"
            android:stepSize="0.5"
            android:progressTint="#2196F3"
            android:secondaryProgressTint="#90CAF9"
            android:progressBackgroundTint="#B0BEC5" />

        <TextView
            android:id="@+id/txtRatingValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5.0"
            android:textColor="#78909C"
            android:textSize="14sp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="20dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@android:drawable/toast_frame"
            android:backgroundTint="#C5CAE9"
            android:padding="10dp"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/edtFeedback"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Share your feedback..."
                android:textColorHint="#78909C"
                android:textColor="#1A237E"
                android:gravity="top|start"
                android:textSize="15sp"
                android:inputType="textMultiLine"
                android:layout_toStartOf="@id/btnSendFeedback"
                android:layout_marginEnd="10dp" />

            <ImageView
                android:id="@+id/btnSendFeedback"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_marginEnd="26dp"
                android:layout_marginBottom="81dp"
                android:src="@android:drawable/ic_menu_send"
                app:tint="#2196F3" />
        </RelativeLayout>

        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="160dp"
            android:layout_height="48dp"
            android:text="Submit"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5C6BC0"
            android:layout_marginBottom="15dp" />

        <Button
            android:id="@+id/btnDisplayReviews"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Display previous reviews"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5C6BC0" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:background="#D0E8F2"
        android:orientation="horizontal"
        android:weightSum="4"
        android:elevation="12dp">

        <LinearLayout
            android:id="@+id/navHomeLayout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/home" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="11sp"
                android:textColor="#555555"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPharmacyLayout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/pharmacy" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pharmacy"
                android:textSize="11sp"
                android:textColor="#555555"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navChannelingLayout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/echaneling" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="E-Channeling"
                android:textSize="11sp"
                android:textColor="#555555"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSearchLayout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/account" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Account"
                android:textSize="11sp"
                android:textColor="#555555"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>