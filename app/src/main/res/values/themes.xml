        <item name="colorPrimaryDark">#000080</item>
        <item name="colorSecondary">#03DAC6</item>
        <item name="colorAccent" tools:ignore="NewApi">#5C5CE0</item>

        <item name="android:windowBackground">#F4FAFF</item>

